# ─── Database (local Postgres) ────────────────────────────────────────────
# Uses your local Homebrew Postgres. `npm run db:setup` creates the schema.
DATABASE_URL=postgres://localhost:5432/hap_voice

# ─── Server ───────────────────────────────────────────────────────────────
PORT=3010
# Public base host Twilio uses to reach this server (no protocol).
# In local dev this is your ngrok/cloudflared tunnel host, e.g. abc123.ngrok-free.app
PUBLIC_HOST=

# ─── Twilio ───────────────────────────────────────────────────────────────
# Only needed for signature validation of incoming webhooks (recommended in prod).
TWILIO_AUTH_TOKEN=
# Set to "true" in local dev to skip Twilio signature validation.
TWILIO_SKIP_VALIDATION=true

# ─── LLM (OpenRouter) ─────────────────────────────────────────────────────
OPENROUTER_API_KEY=
# A fast, cheap model works well for live conversation. Append :nitro to route to
# the fastest provider. Changeable live from the Settings page.
OPENROUTER_MODEL=google/gemini-2.5-flash-lite

# ─── Speech-to-text (local whisper.cpp — free) ────────────────────────────
STT_PROVIDER=whisper
WHISPER_CLI=/opt/homebrew/bin/whisper-cli
WHISPER_MODEL=./models/ggml-base.en.bin

# ─── Text-to-speech ───────────────────────────────────────────────────────
# say = macOS built-in (free, local, dev). piper = free neural (portable, prod).
# elevenlabs = premium (needs key).
TTS_PROVIDER=say
SAY_VOICE=Samantha

# Piper (only if TTS_PROVIDER=piper)
PIPER_BIN=/opt/homebrew/bin/piper
PIPER_VOICE=./models/en_US-lessac-medium.onnx

# ElevenLabs (only if TTS_PROVIDER=elevenlabs) — natural voice, free tier works
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# eleven_flash_v2_5 = fastest; eleven_turbo_v2_5 = richer but a touch slower
ELEVENLABS_MODEL=eleven_flash_v2_5

# ─── Assistant persona ────────────────────────────────────────────────────
BUSINESS_NAME=HelpAProduct
ASSISTANT_GREETING=Thanks for calling HelpAProduct. This is the assistant — who am I speaking with?
