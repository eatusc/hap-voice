# hap-voice configuration — copy to .env.local and fill in.
# .env.local is gitignored; never commit real secrets.

# ─── Database (local Postgres) ────────────────────────────────────────────
# `npm run db:setup` creates the schema in this database.
DATABASE_URL=postgres://localhost:5432/hap_voice

# ─── Server ───────────────────────────────────────────────────────────────
PORT=3010
# Public base host webhooks reach this server on (no protocol).
# Local dev: your ngrok/cloudflared tunnel host, e.g. abc123.ngrok-free.app
PUBLIC_HOST=

# ─── Twilio ───────────────────────────────────────────────────────────────
# Needed for webhook signature validation (always on in production).
TWILIO_AUTH_TOKEN=
# "true" skips Twilio signature validation — honored ONLY when
# NODE_ENV != production. Ignored on a live deployment. Use for local dev only.
TWILIO_SKIP_VALIDATION=false

# ─── LLM (OpenRouter) ─────────────────────────────────────────────────────
OPENROUTER_API_KEY=
# A fast, cheap model works well for live conversation.
OPENROUTER_MODEL=openai/gpt-4o-mini

# ─── Speech-to-text (local whisper.cpp — free) ────────────────────────────
STT_PROVIDER=whisper
WHISPER_CLI=/opt/homebrew/bin/whisper-cli
WHISPER_MODEL=./models/ggml-base.en.bin

# ─── Text-to-speech ───────────────────────────────────────────────────────
# TTS_PROVIDER: say (macOS, dev) | piper (local neural) | kokoro (local neural) | elevenlabs (paid)
TTS_PROVIDER=say
SAY_VOICE=Samantha

# Piper (only if TTS_PROVIDER=piper)
PIPER_BIN=/opt/homebrew/bin/piper
PIPER_VOICE=./models/en_US-lessac-medium.onnx

# ElevenLabs (only if TTS_PROVIDER=elevenlabs)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_flash_v2_5

# Kokoro (only if TTS_PROVIDER=kokoro) — local Python service, see kokoro/
KOKORO_URL=http://127.0.0.1:5111

# ─── Assistant persona ────────────────────────────────────────────────────
BUSINESS_NAME=YourBusiness
ASSISTANT_GREETING=Thanks for calling. This is the assistant — who am I speaking with?

# ─── Voice provider (see RETELL.md) ───────────────────────────────────────
# local = self-hosted pipeline above | retell = hand off to a Retell AI agent
VOICE_PROVIDER=local
# A freshly created/rotated Retell API key — the only required entry for Retell.
RETELL_API_KEY=
# Optional: leave blank and the Settings page creates the agent for you.
RETELL_AGENT_ID=
# "true" skips Retell signature validation — honored ONLY when NODE_ENV != production.
RETELL_SKIP_VALIDATION=false
